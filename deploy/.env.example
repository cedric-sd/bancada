# Copie para `.env` NA VPS (em ~/bancada/.env) e preencha. NÃO comitar o .env.
# O docker-compose.yml lê estas variáveis.

# Domínio público que aponta (registro A) para o IP da VPS. Usado na regra de
# roteamento do Traefik (Host).
DOMAIN=bancada.seudominio.com

# Traefik (opcionais — só mude se o seu Traefik usar outros nomes).
# Padrões: entrypoint HTTPS "websecure" e certresolver ACME "letsencrypt".
# TRAEFIK_ENTRYPOINT=websecure
# TRAEFIK_CERTRESOLVER=letsencrypt

# --- Login com GitHub (opcional) ---
# Crie um OAuth App em github.com/settings/developers com o callback:
#   https://SEU_DOMINIO/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Precisa bater exatamente com o callback do OAuth App acima.
GITHUB_REDIRECT_URI=https://bancada.seudominio.com/api/auth/github/callback

# --- Estrelas do GitHub (opcional) ---
# PAT (sem escopos, ou public_repo) só para elevar o rate limit ao buscar estrelas.
GITHUB_TOKEN=

# --- Dados de demonstração (opcional) ---
# Em produção o banco inicia LIMPO por padrão (sem projetos/votantes fictícios).
# Defina SEED_DEMO=1 só se quiser popular um banco vazio com a vitrine de exemplo.
# SEED_DEMO=1
